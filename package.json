{
  "name": "rekon",
  "version": "1.0.0",
  "private": true,
  "description": "Open-source intelligence substrate for codebases.",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc -b",
    "test": "node scripts/test.mjs",
    "test:smoke": "node scripts/test.mjs --suite smoke",
    "test:contract": "node scripts/test.mjs --suite contract",
    "test:live": "node scripts/test.mjs --suite live",
    "test:bench": "node scripts/test.mjs --suite bench",
    "bench:gap-review": "node tests/bench/redesign-gap-review.mjs",
    "bench:quality-review": "node tests/bench/emission-quality-review.mjs",
    "bench:public-corpus:setup": "node tests/bench/setup-public-corpus.mjs",
    "test:install": "node scripts/install-smoke.mjs",
    "bench:incremental": "npm run build --workspaces && node scripts/benchmark-incremental.mjs",
    "build": "npm run build --workspaces",
    "audit:detection-quality": "npm run build --workspaces && node scripts/audit-detection-quality.mjs",
    "report:detection-quality": "npm run build --workspaces && node scripts/report-detection-quality.mjs",
    "eval:semantic-debt": "npm run build --workspaces && node scripts/eval-semantic-debt-models.mjs",
    "eval:voyage-embeddings": "npm run build --workspaces && node scripts/eval-voyage-embeddings.mjs",
    "eval:embedding-duplicates": "npm run build --workspaces && node scripts/eval-embedding-duplicates.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": "^20.12 || ^22 || ^24"
  }
}
