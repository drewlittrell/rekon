      "claim": {
        "category": "scope-resolution",
        "proof": "upstream-regression-test",
        "summary": "A case-local declaration could cause imported references to throw ReferenceError after SSR transformation."
      },
      "affectedPaths": ["packages/vite/src/node/ssr/ssrTransform.ts"],
      "testPaths": ["packages/vite/src/node/ssr/__tests__/ssrTransform.spec.ts"]
