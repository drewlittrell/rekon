    "architecture.importCycle": { "minimumUsefulness": 0.75 },
    "architecture.noUnknownSystemForSourceFile": { "minimumUsefulness": 0.75 },
    "capability.overlap": { "minimumUsefulness": 0.75 },
    "dead_code.emptySourceFile": { "minimumUsefulness": 0.75 },
    "dead_code.unreferenced": { "minimumUsefulness": 0.75 },
    "debt.markers": { "minimumUsefulness": 0.75 },
    "debt.semantic": { "minimumUsefulness": 0.75 },
    "events.inverseListenerDelegation": { "minimumUsefulness": 0.75 },
    "files.noGeneratedAsSource": { "minimumPrecision": 0.9 },
    "grammar.antiPattern": { "minimumPrecision": 0.9 },
    "grammar.divergence": { "minimumPrecision": 0.9 },
    "imports.noDistImports": { "minimumPrecision": 0.9 },
    "imports.noNodeModulesRelativeImports": { "minimumPrecision": 0.9 },
