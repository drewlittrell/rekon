    "typescript.compilerDiagnostic": { "minimumPrecision": 0.9 },
    "typescript.errorSuppression": { "minimumUsefulness": 0.75 },
    "typescript.functionComplexity": { "minimumUsefulness": 0.75 },
    "typescript.placeholderImplementation": { "minimumUsefulness": 0.75 },
    "typescript.typeEscape": { "minimumUsefulness": 0.75 },
    "typescript.unreachableCode": { "minimumUsefulness": 0.75 },
    "typescript.unusedImport": { "minimumUsefulness": 0.75 },
    "typescript.unusedPrivateMember": { "minimumUsefulness": 0.75 },
