{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "FixtureScanner",
          "semanticVersion": "1.0.0",
          "rules": [
            {
              "id": "fixture/unsafe-input",
              "properties": {
                "tags": ["security", "external/cwe/cwe-020"],
                "security-severity": "7.5",
                "precision": "high"
              }
            }
          ]
        }
      },
      "invocations": [{ "executionSuccessful": true }],
      "results": [
        {
          "ruleId": "fixture/unsafe-input",
          "ruleIndex": 0,
          "level": "error",
          "message": { "text": "Untrusted input reaches a sensitive operation." },
          "partialFingerprints": { "primaryLocationLineHash/v1": "fixture-security-result" },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/index.ts" },
                "region": { "startLine": 3, "startColumn": 1 }
              }
            }
          ]
        }
      ]
    }
  ]
}
