            "systemId": "experience-intelligence",
            "name": "Experience intelligence",
            "scope": { "paths": ["src/nlu/**"] },
            "purpose": "Interpret flexible experience language through atomic vocabulary and compositional meaning.",
            "userOutcomes": ["Equivalent expressions resolve without phrase-by-phrase training."],
            "invariants": [
              {
                "id": "atomic-composition",
                "statement": "Support new expressions through reusable atomic concepts or syntax, never complete phrase aliases."
              },
              {
                "id": "unknown-evidence",
                "statement": "Preserve non-connector unknown tokens as evidence for later interpretation."
              }
            ],
            "prohibitedChanges": [
              {
                "id": "no-phrase-overfit",
                "statement": "Do not add a complete user phrase to the vocabulary as a special case."
              }
            ],
            "requiredContextPaths": [
              "src/nlu/vocabulary.ts",
              "src/nlu/tokenize.ts",
              "src/nlu/atomize.ts",
              "src/nlu/compose-meaning.ts",
