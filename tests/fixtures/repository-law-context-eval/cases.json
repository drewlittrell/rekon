            "systemId": "checkout-processing",
            "name": "Checkout processing",
            "scope": { "paths": ["src/checkout/**"] },
            "purpose": "Create and process checkout messages without losing request identity or optional metadata.",
            "userOutcomes": ["Receipts describe the same checkout request accepted by the API."],
            "invariants": [
              {
                "id": "request-id-preserved",
                "statement": "Preserve requestId unchanged from CheckoutRequest through receipt publication."
              },
              {
                "id": "optional-campaign",
                "statement": "campaignId remains optional and must be omitted, not serialized as undefined, when absent."
              }
            ],
            "prohibitedChanges": [
              {
                "id": "no-generated-request-id",
                "statement": "Do not replace the caller-provided requestId inside checkout processing."
              }
            ],
            "requiredContextPaths": [
              "src/api/checkout-controller.ts",
              "src/checkout/checkout-message.ts",
              "src/checkout/checkout-service.ts",
              "src/worker/checkout-worker.ts",
              "src/receipts/receipt-publisher.ts",
              "tests/checkout-flow.test.ts"
            ],
            "requiredChecks": ["npm test"]
          }
        ],
        "flows": [
          {
            "id": "experience-interpretation-flow",
            "name": "Experience interpretation",
            "criticality": "high",
            "purpose": "Carry user language through tokenization, atomization, and composition without phrase overfitting.",
            "userOutcomes": ["Users can express familiar concepts in new combinations."],
            "entryConditions": ["The API receives non-empty experience text."],
            "completionConditions": ["The interpreter returns composed concepts or explicit unknown tokens."],
            "systems": ["experience-intelligence"],
            "paths": [
              "src/nlu/vocabulary.ts",
              "src/nlu/tokenize.ts",
              "src/nlu/atomize.ts",
              "src/nlu/compose-meaning.ts",
              "src/nlu/experience-interpreter.ts",
              "tests/experience-interpreter.test.ts"
            ],
            "invariants": [
              {
                "id": "phrase-independent",
                "statement": "A phrase succeeds because its reusable atoms compose, not because the complete phrase is stored."
              },
              {
                "id": "token-accounting",
                "statement": "Carry every non-connector token into either recognized concepts or unknown-token evidence."
              }
            ],
            "stages": [
              { "id": "tokenize", "systemId": "experience-intelligence", "paths": ["src/nlu/tokenize.ts"] },
              { "id": "atomize", "systemId": "experience-intelligence", "paths": ["src/nlu/vocabulary.ts", "src/nlu/atomize.ts"] },
              { "id": "compose", "systemId": "experience-intelligence", "paths": ["src/nlu/compose-meaning.ts", "src/nlu/experience-interpreter.ts"] }
            ],
            "handoffs": [
              {
                "id": "tokens-to-atoms",
                "fromStageId": "tokenize",
                "toStageId": "atomize",
                "payload": { "schema": "string[]" },
                "guarantees": ["Connector tokens are removed while remaining tokens keep their normalized meaning."],
                "carriedInvariantIds": ["token-accounting"]
              },
              {
                "id": "atoms-to-meaning",
                "fromStageId": "atomize",
                "toStageId": "compose",
                "guarantees": ["Recognized concepts and unknown tokens cross the handoff separately."],
                "carriedInvariantIds": ["phrase-independent", "token-accounting"]
              }
            ],
            "requiredChecks": ["npm test"]
          },
          {
            "id": "checkout-receipt-flow",
            "name": "Checkout receipt",
            "criticality": "critical",
            "purpose": "Carry checkout identity and optional campaign metadata from request acceptance to receipt publication.",
            "userOutcomes": ["The receipt can be correlated to the request and its optional campaign."],
            "entryConditions": ["A valid CheckoutRequest reaches the controller."],
            "completionConditions": ["A receipt is published for the same request and order."],
            "systems": ["checkout-processing", "checkout-worker", "receipts"],
            "paths": [
              "src/api/checkout-controller.ts",
              "src/checkout/checkout-message.ts",
              "src/checkout/checkout-service.ts",
              "src/worker/checkout-worker.ts",
