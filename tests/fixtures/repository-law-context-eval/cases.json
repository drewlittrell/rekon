              "tests/checkout-flow.test.ts"
            ],
            "invariants": [
              {
                "id": "flow-request-id",
                "statement": "Every checkout handoff carries the original requestId unchanged."
              },
              {
                "id": "flow-optional-campaign",
                "statement": "Every checkout handoff preserves campaignId when present and omits it when absent."
              }
            ],
            "stages": [
              { "id": "accept", "systemId": "checkout-processing", "paths": ["src/api/checkout-controller.ts", "src/checkout/checkout-service.ts"] },
              { "id": "queue", "systemId": "checkout-processing", "paths": ["src/checkout/checkout-message.ts"] },
              { "id": "process", "systemId": "checkout-worker", "paths": ["src/worker/checkout-worker.ts"] },
              { "id": "publish", "systemId": "receipts", "paths": ["src/receipts/receipt-publisher.ts"] }
            ],
            "handoffs": [
              {
                "id": "request-to-message",
                "fromStageId": "accept",
                "toStageId": "queue",
                "payload": { "schema": "CheckoutMessage", "requiredFields": ["requestId", "orderId"] },
                "guarantees": ["The message preserves requestId and only includes campaignId when supplied."],
                "carriedInvariantIds": ["flow-request-id", "flow-optional-campaign"]
              },
              {
                "id": "message-to-worker",
                "fromStageId": "queue",
                "toStageId": "process",
                "payload": { "schema": "CheckoutMessage", "requiredFields": ["requestId", "orderId"] },
                "guarantees": ["The worker receives the same checkout identity and campaign metadata."],
                "carriedInvariantIds": ["flow-request-id", "flow-optional-campaign"]
              },
              {
                "id": "worker-to-receipt",
                "fromStageId": "process",
                "toStageId": "publish",
                "payload": { "schema": "ReceiptMetadata", "requiredFields": ["requestId", "orderId"] },
                "guarantees": ["Receipt metadata remains correlated to the original request."],
                "carriedInvariantIds": ["flow-request-id", "flow-optional-campaign"]
              }
            ],
