    "@rekon/capability-policy": "1.0.0",
    "@rekon/capability-reconcile": "1.0.0",
    "@rekon/capability-resolver": "1.0.0",
    "@rekon/capability-verify": "1.0.0",
    "@rekon/llm-provider": "1.0.0",
    "@rekon/kernel-artifacts": "1.0.0",
    "@rekon/kernel-findings": "1.0.0",
